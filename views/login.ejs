<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Granted | Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; color: #e2e8f0; min-height: 100vh; overflow: hidden; }
        .rain { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
        .drop { position: absolute; background: rgba(255, 255, 255, 0.1); width: 1px; height: 80px; animation: fall 1s linear infinite; }
        @keyframes fall { to { transform: translateY(100vh); } }
        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); }
    </style>
</head>
<body class="flex items-center justify-center">
    <div class="rain"></div>
    
    <div class="glass p-8 rounded-2xl shadow-2xl w-full max-w-md z-10 mx-4">
        <h1 class="text-3xl font-bold mb-6 text-center tracking-tight">System Login</h1>
        <form action="/auth/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium mb-1 opacity-70">Email</label>
                <input type="email" name="email" required class="w-full bg-slate-800/50 border border-white/10 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500/50">
            </div>
            <div>
                <label class="block text-sm font-medium mb-1 opacity-70">Password</label>
                <input type="password" name="password" required class="w-full bg-slate-800/50 border border-white/10 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500/50">
            </div>
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 transition-colors text-white font-semibold py-2 rounded-lg mt-4">
                Authorize
            </button>
        </form>
        <p class="mt-6 text-center text-sm opacity-60">
            New here? <a href="/auth/register" class="text-indigo-400 hover:underline">Create Account</a> | <a href="/" class="text-indigo-400 hover:underline">Home</a>
        </p>
    </div>

    <script>
        const rain = document.querySelector('.rain');
        for (let i = 0; i < 60; i++) {
            const drop = document.createElement('div');
            drop.classList.add('drop');
            drop.style.left = Math.random() * 100 + 'vw';
            drop.style.animationDuration = Math.random() * 0.5 + 0.7 + 's';
            drop.style.animationDelay = Math.random() * 2 + 's';
            rain.appendChild(drop);
        }
    </script>
</body>
</html>