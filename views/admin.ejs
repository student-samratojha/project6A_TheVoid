<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Command Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #020617; color: #f1f5f9; min-height: 100vh; }
        .rain { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
        .drop { position: absolute; background: rgba(255, 255, 255, 0.05); width: 1px; height: 100px; animation: fall 1s linear infinite; }
        @keyframes fall { to { transform: translateY(100vh); } }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.05); }
    </style>
</head>
<body class="p-6 md:p-12">
    <div class="rain"></div>
    
    <div class="max-w-6xl mx-auto relative z-10">
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
            <div>
                <h1 class="text-5xl font-black tracking-tighter text-blue-500 uppercase">Void Control</h1>
                <p class="opacity-40 text-sm tracking-widest mt-1">SYSTEM ADMINISTRATION TERMINAL</p>
            </div>
            
            <!-- Admin Info Card -->
            <div class="glass p-4 rounded-2xl flex items-center gap-4 min-w-[280px]">
                <div class="w-12 h-12 rounded-full bg-blue-500/20 flex items-center justify-center border border-blue-500/30">
                    <span class="text-xl font-bold text-blue-400"><%= admin.name.charAt(0) %></span>
                </div>
                <div class="flex-1">
                    <p class="text-sm font-bold truncate"><%= admin.name %></p>
                    <p class="text-[10px] opacity-50 uppercase tracking-tighter"><%= admin.email %></p>
                </div>
                <a href="/auth/logout" class="p-2 hover:bg-red-500/20 rounded-lg transition text-red-400" title="Logout">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                </a>
            </div>
        </header>

        <!-- Section: Users -->
        <section class="mb-16">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-blue-500"></span> User Registry
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (locals.users) { %>
                    <% users.forEach(u => { %>
                        <div class="glass p-6 rounded-2xl relative border-l-4 <%= u.isDeleted ? 'border-red-500/50' : 'border-green-500/50' %>">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h3 class="font-bold text-lg"><%= u.name %></h3>
                                    <p class="text-xs opacity-40"><%= u.email %></p>
                                </div>
                                <span class="text-[10px] px-2 py-1 rounded bg-slate-800 text-slate-400 border border-white/5 uppercase"><%= u.streak %> 🔥</span>
                            </div>
                            <div class="flex justify-between items-center mt-6">
                                <span class="text-[10px] uppercase font-bold tracking-widest <%= u.isDeleted ? 'text-red-400' : 'text-green-400' %>">
                                    <%= u.isDeleted ? 'Suspended' : 'Active' %>
                                </span>
                                <form action="/secure/<%= u.isDeleted ? 'restore' : 'delete' %>" method="POST">
                                    <input type="hidden" name="id" value="<%= u._id %>">
                                    <button class="text-xs px-4 py-1.5 rounded-full border border-white/10 hover:bg-white/5 transition">
                                        <%= u.isDeleted ? 'Restore' : 'Suspend' %>
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </section>

        <!-- Section: Global Tasks -->
        <section class="mb-16">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2 text-indigo-400">
                <span class="w-2 h-2 rounded-full bg-indigo-500"></span> Global Task Monitor
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (locals.tasks) { %>
                    <% tasks.forEach(task => { %>
                        <div class="glass p-5 rounded-2xl">
                            <div class="flex justify-between mb-4">
                                <span class="text-[9px] px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase tracking-widest"><%= task.category %></span>
                                <span class="text-[9px] text-slate-500 italic">By <%= task.userId ? task.userId.name : 'Unknown' %></span>
                            </div>
                            <h3 class="font-bold mb-2 truncate"><%= task.title %></h3>
                            <p class="text-xs opacity-40 line-clamp-2 mb-4"><%= task.description || 'No description provided.' %></p>
                            <div class="flex items-center justify-between text-[10px] uppercase font-bold">
                                <span class="<%= task.status === 'completed' ? 'text-green-400' : 'text-amber-400' %> tracking-tighter">● <%= task.status %></span>
                                <span class="opacity-30">P: <%= task.priority %></span>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </section>

        <!-- Section: Global Sessions -->
        <section class="mb-12">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2 text-purple-400">
                <span class="w-2 h-2 rounded-full bg-purple-500"></span> Analytics: Recent Sessions
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <% if (locals.sessions) { %>
                    <% sessions.forEach(session => { %>
                        <div class="glass p-4 rounded-xl border-b-2 border-purple-500/20">
                            <p class="text-[10px] opacity-40 uppercase mb-1 font-black"><%= session.sessionType %></p>
                            <h4 class="text-sm font-bold truncate mb-2 text-purple-100">
                                <%= session.taskId ? session.taskId.title : 'General Session' %>
                            </h4>
                            <div class="flex justify-between items-end mt-4">
                                <p class="text-2xl font-black tracking-tighter"><%= session.duration %><span class="text-[10px] ml-1 opacity-40">MIN</span></p>
                                <p class="text-xs font-mono text-purple-400">Score: <%= session.productivityScore %></p>
                            </div>
                            <p class="text-[9px] opacity-30 mt-2 truncate">Operator: <%= session.userId ? session.userId.name : 'N/A' %></p>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </section>

        <!-- Section: System Audit Logs -->
        <section class="mb-12">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2 text-red-400">
                <span class="w-2 h-2 rounded-full bg-red-500"></span> System Audit Logs
            </h2>
            <div class="glass rounded-2xl overflow-hidden border border-white/5">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white/5 text-[10px] uppercase tracking-widest opacity-50">
                                <th class="p-4 font-bold">Timestamp</th>
                                <th class="p-4 font-bold">Operator</th>
                                <th class="p-4 font-bold">Action</th>
                                <th class="p-4 font-bold">Endpoint</th>
                                <th class="p-4 font-bold">IP Address</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs">
                            <% if (locals.audits && audits.length > 0) { %>
                                <% audits.forEach(log => { %>
                                    <tr class="border-t border-white/5 hover:bg-white/[0.02] transition-colors">
                                        <td class="p-4 opacity-60 font-mono"><%= new Date(log.createdAt).toLocaleString() %></td>
                                        <td class="p-4">
                                            <div class="flex items-center gap-2">
                                                <div class="w-6 h-6 rounded-full bg-blue-500/20 flex items-center justify-center text-[10px] text-blue-400 border border-blue-500/20">
                                                    <%= log.user ? log.user.name.charAt(0) : '?' %>
                                                </div>
                                                <span class="font-medium"><%= log.user ? log.user.name : 'Guest/System' %></span>
                                            </div>
                                        </td>
                                        <td class="p-4">
                                            <span class="px-2 py-0.5 rounded bg-red-500/10 text-red-400 border border-red-500/10 font-semibold text-[10px] uppercase"><%= log.action %></span>
                                        </td>
                                        <td class="p-4">
                                            <span class="opacity-40 text-[10px] font-bold"><%= log.method %></span> 
                                            <code class="text-blue-300 bg-blue-500/5 px-1.5 py-0.5 rounded ml-1 font-mono text-[10px]"><%= log.route %></code>
                                        </td>
                                        <td class="p-4 font-mono opacity-40"><%= log.ip %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="p-8 text-center opacity-30 italic">No audit records found in terminal history.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </div>

    <script>
        const rain = document.querySelector('.rain');
        for (let i = 0; i < 70; i++) {
            const drop = document.createElement('div');
            drop.classList.add('drop');
            drop.style.left = Math.random() * 100 + 'vw';
            drop.style.animationDuration = Math.random() * 0.3 + 0.7 + 's';
            drop.style.animationDelay = Math.random() * 2 + 's';
            rain.appendChild(drop);
        }
    </script>
</body>
</html>