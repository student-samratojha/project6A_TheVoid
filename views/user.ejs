<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Terminal | Workspace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #020617; color: #f1f5f9; min-height: 100vh; }
        .rain { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
        .drop { position: absolute; background: rgba(255, 255, 255, 0.05); width: 1px; height: 100px; animation: fall 1.2s linear infinite; }
        @keyframes fall { to { transform: translateY(100vh); } }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.05); }
    </style>
</head>
<body class="p-6 md:p-12">
    <div class="rain"></div>
    
    <div class="max-w-5xl mx-auto relative z-10">
        <header class="flex justify-between items-center mb-12">
            <div>
                <h1 class="text-4xl font-bold tracking-tight">Welcome, <%= user.name %></h1>
                <p class="opacity-50">Current Streak: <span class="text-orange-400"><%= user.streak %> 🔥</span></p>
            </div>
            <div class="flex gap-4">
                <a href="/secure/make" class="glass px-6 py-2 rounded-full hover:bg-white/10 transition">New Task</a>
                <a href="/auth/logout" class="text-red-400 border border-red-400/30 px-6 py-2 rounded-full hover:bg-red-400/10 transition">Logout</a>
            </div>
        </header>

        <main class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            <% if (tasks && tasks.length > 0) { %>
                <% tasks.forEach(task => { %>
                    <div class="glass p-6 rounded-2xl flex flex-col justify-between">
                        <div>
                            <div class="flex flex-wrap gap-2 justify-between items-start mb-4">
                                <div class="flex gap-2">
                                    <span class="text-[10px] uppercase tracking-widest px-2 py-1 rounded bg-slate-800 text-slate-400 border border-white/5">
                                        <%= task.priority %>
                                    </span>
                                    <span class="text-[10px] uppercase tracking-widest px-2 py-1 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">
                                        <%= task.category %>
                                    </span>
                                </div>
                                <span class="text-xs font-medium <%= task.status === 'completed' ? 'text-green-400' : 'text-yellow-400' %>">
                                    ● <%= task.status %>
                                </span>
                            </div>
                            <h3 class="text-xl font-bold mb-2 tracking-tight"><%= task.title %></h3>
                            <% if (task.description) { %>
                                <p class="text-sm opacity-50 mb-4 leading-relaxed line-clamp-2"><%= task.description %></p>
                            <% } %>
                            
                            <div class="space-y-1 mb-6 text-[10px] uppercase tracking-tighter opacity-40">
                                <% if (task.deadline) { %>
                                    <p>Target: <%= new Date(task.deadline).toDateString() %></p>
                                <% } %>
                                <p>Initiated: <%= new Date(task.createdAt).toDateString() %></p>
                                <% if (task.completedAt) { %>
                                    <p class="text-green-400/80">Finalized: <%= new Date(task.completedAt).toDateString() %></p>
                                <% } %>
                            </div>
                        </div>
                        
                        <div class="flex gap-2">
                            <% if (task.status === 'pending') { %>
                                <form action="/secure/complete" method="POST" class="flex-1">
                                    <input type="hidden" name="id" value="<%= task._id %>">
                                    <button class="w-full text-sm bg-green-600/20 text-green-400 border border-green-400/30 py-2 rounded-lg hover:bg-green-600/40 transition">Complete</button>
                                </form>
                            <% } %>
                            <form action="/secure/delete" method="POST" class="flex-1">
                                <input type="hidden" name="id" value="<%= task._id %>">
                                <button class="w-full text-sm bg-red-600/20 text-red-400 border border-red-400/30 py-2 rounded-lg hover:bg-red-600/40 transition">Delete</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full glass p-12 text-center rounded-2xl opacity-40">
                    No active tasks. Time to focus on the rain.
                </div>
            <% } %>
        </main>

        <section class="mt-20 relative z-10">
            <div class="flex items-center gap-4 mb-8">
                <h2 class="text-3xl font-bold tracking-tight">Focus History</h2>
                <div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
            </div>

            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                <% if (sessions && sessions.length > 0) { %>
                    <% sessions.forEach(session => { %>
                        <div class="glass p-6 rounded-2xl border-l-2 border-indigo-500/30">
                            <div class="flex justify-between items-start mb-4">
                                <span class="text-[10px] uppercase tracking-widest px-2 py-1 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">
                                    <%= session.sessionType %>
                                </span>
                                <div class="flex items-center gap-1">
                                    <span class="text-[10px] opacity-40 uppercase tracking-tighter mr-2">Efficiency</span>
                                    <% for(let i=0; i<5; i++) { %>
                                        <div class="w-1 h-3 rounded-full <%= i < Math.round(session.productivityScore/2) ? 'bg-indigo-400' : 'bg-slate-700' %>"></div>
                                    <% } %>
                                </div>
                            </div>
                            
                            <% if (session.taskId && typeof session.taskId === 'object') { %>
                                <div class="mb-4 p-3 bg-white/5 rounded-xl border border-white/5 group hover:border-indigo-500/20 transition-colors">
                                    <p class="text-[9px] uppercase tracking-widest opacity-40 mb-1">Target Objective</p>
                                    <div class="flex items-center justify-between gap-2">
                                        <p class="text-xs font-bold text-indigo-100 truncate"><%= session.taskId.title %></p>
                                        <span class="text-[8px] px-1.5 py-0.5 rounded bg-slate-800 text-green-500 border border-white/5 uppercase">
                                            <%= session.taskId.category %>
                                        </span>
                                    </div>
                                </div>
                            <% } %>

                            <div class="flex items-baseline gap-2 mb-2">
                                <span class="text-3xl font-black tracking-tighter text-white">
                                    <%= session.duration %>
                                </span>
                                <span class="text-xs uppercase opacity-40 font-bold">Minutes Logged</span>
                            </div>

                            <% if (session.note) { %>
                                <p class="text-sm text-slate-400 mb-6 italic leading-relaxed line-clamp-2">
                                    "<%= session.note %>"
                                </p>
                            <% } %>

                            <div class="pt-4 border-t border-white/5 flex justify-between items-center text-[10px] uppercase tracking-widest opacity-40 font-bold">
                                <span><%= new Date(session.date || session.createdAt).toLocaleString() %></span>
                                <span>Score: <%= session.productivityScore %>/10</span>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full glass p-12 text-center rounded-2xl opacity-40">
                        The archives are empty. Complete tasks to record focus sessions.
                    </div>
                <% } %>
            </div>
        </section>

        <% if (locals.query && query.error) { %>
            <div class="fixed bottom-8 right-8 bg-red-500/80 text-white px-6 py-3 rounded-lg backdrop-blur-md">
                <%= query.error %>
            </div>
        <% } %>
    </div>

    <script>
        const rain = document.querySelector('.rain');
        for (let i = 0; i < 80; i++) {
            const drop = document.createElement('div');
            drop.classList.add('drop');
            drop.style.left = Math.random() * 100 + 'vw';
            drop.style.animationDuration = Math.random() * 0.4 + 0.8 + 's';
            drop.style.animationDelay = Math.random() * 5 + 's';
            rain.appendChild(drop);
        }
        // Auto-hide messages
        setTimeout(() => {
            const msg = document.querySelector('.fixed');
            if(msg) msg.style.display = 'none';
        }, 3000);
    </script>
</body>
</html>